<Window x:Class="part.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LockWise AI"
        Height="650"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="MidnightBlue">

    <Grid>

        <!-- HEADER -->
        <Border Background="DarkSlateBlue"
                Height="80"
                VerticalAlignment="Top">

            <StackPanel Margin="20,10">

                <TextBlock Text=" LockWise AI"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Text="Cybersecurity Awareness Assistant"
                           Foreground="DeepSkyBlue"
                           FontSize="15"/>

            </StackPanel>

        </Border>

        <!-- LEFT PANEL -->
        <Border Background="DarkSlateBlue"
                Width="220"
                Margin="10,100,0,10"
                HorizontalAlignment="Left"
                CornerRadius="10">

            <StackPanel Margin="10">

                <TextBlock Text="Quick Actions"
                           Foreground="DeepSkyBlue"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="10"/>

                <Button x:Name="btnPassword"
                        Content=" Password Safety"
                        Height="45"
                        Margin="5"
                        Background="DeepSkyBlue"
                        Foreground="White"/>

                <Button x:Name="btnPhishing"
                        Content=" Phishing"
                        Height="45"
                        Margin="5"
                        Background="MediumPurple"
                        Foreground="White"/>

                <Button x:Name="btnBrowsing"
                        Content=" Safe Browsing"
                        Height="45"
                        Margin="5"
                        Background="DeepSkyBlue"
                        Foreground="White"/>

                <Button x:Name="btnHelp"
                        Content=" Help"
                        Height="45"
                        Margin="5"
                        Background="MediumPurple"
                        Foreground="White"/>

                <Button x:Name="btnClear"
                        Content=" Clear Chat"
                        Height="45"
                        Margin="5"
                        Background="IndianRed"
                        Foreground="White"/>

            </StackPanel>

        </Border>

        <!-- CHAT AREA -->
        <Border Background="#1E293B"
                Margin="240,100,20,100"
                CornerRadius="15">

            <ScrollViewer x:Name="ChatScrollViewer"
              VerticalScrollBarVisibility="Auto">
                
                <StackPanel x:Name="ChatPanel"
                            Margin="15">

                    <Border Background="MediumPurple"
                            CornerRadius="12"
                            Padding="12"
                            Margin="5"
                            HorizontalAlignment="Left"
                            MaxWidth="400">

                        <TextBlock Text="LockWise: Hello! Welcome to LockWise AI. What is your name?."
                                   Foreground="White"
                                   FontSize="16"
                                   TextWrapping="Wrap"/>

                    </Border>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- INPUT AREA -->
        <Border Background="DarkSlateBlue"
                Height="75"
                VerticalAlignment="Bottom"
                Margin="240,0,20,10"
                CornerRadius="15">

            <Grid>

                <TextBox x:Name="txtUserInput"
                         KeyDown="txtUserInput_KeyDown"

                         Margin="15,15,130,15"
                         FontSize="16"
                         Background="#1E293B"
                         Foreground="White"
                         BorderBrush="DeepSkyBlue"
                         BorderThickness="2"
                         CaretBrush="White"
                         Padding="10"/>

                <Button x:Name="btnSend"
                        Content="Send "
                        Width="90"
                        Height="40"
                        HorizontalAlignment="Right"
                        Margin="0,15,20,15"
                        Background="DeepSkyBlue"
                        Foreground="White"
                        FontWeight="Bold"/>

            </Grid>

        </Border>

    </Grid>

</Window>